{
  "name": "@stellarid/utils",
  "version": "0.1.0",
  "private": true,
  "description": "StellarID utility functions",
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@stellarid/types": "workspace:*",
    "crypto-js": "^4.2.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.1.3",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.2"
  }
}
