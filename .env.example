# Application Environment
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/stellarid
DATABASE_SHADOW_URL=postgresql://user:password@localhost:5432/stellarid_shadow

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_WALLET_NETWORK=testnet
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# Backend
PORT=3001
JWT_SECRET=your-secret-key-change-in-production
FREIGHTER_CALLBACK_URL=http://localhost:3000/auth/callback
STELLAR_NETWORK=testnet

# Email Service (Optional)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your-username
SMTP_PASSWORD=your-password
SMTP_FROM=noreply@stellarid.io

# Security
BCRYPT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME_MINUTES=15

# Monitoring (Optional)
SENTRY_DSN=
LOG_LEVEL=info

# Soroban Contract Addresses
SOROBAN_CREDENTIAL_CONTRACT_ID=
SOROBAN_IDENTITY_CONTRACT_ID=

# AWS/Cloud Storage (Optional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
